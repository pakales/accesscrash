{
  "name": "accesscrash",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Human regression testing for student services.",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --import tsx --test tests/*.test.ts",
    "test:render": "npm run build && node --test tests/rendered-html.test.mjs",
    "test": "npm run test:unit && npm run test:render",
    "verify": "npm run lint && npm run typecheck && npm test",
    "audit:prod": "npm audit --omit=dev",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "openai": "^6.48.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.28",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "^19.2.7",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "js-yaml": "4.3.0",
    "postcss": "8.5.20"
  },
  "type": "module"
}
