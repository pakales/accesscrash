# Server-only. Never prefix this variable with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Production fail-safe only. Do not set true before server-side sign-in and
# persistent per-user quota/rate controls are implemented and verified.
ACCESSCRASH_ENABLE_PUBLIC_LIVE_MODEL=false

# Set this to the deployed HTTPS origin before publishing social metadata.
ACCESSCRASH_SITE_URL=http://localhost:3000
